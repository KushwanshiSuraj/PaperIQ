<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="http://xmlns.jcp.org/xml/ns/javaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee 
         http://xmlns.jcp.org/xml/ns/javaee/web-app_4_0.xsd"
         version="4.0">
    
    <display-name>PaperIQ</display-name>
    
    <!-- Welcome page -->
    <welcome-file-list>
        <welcome-file>login.jsp</welcome-file>
        <welcome-file>index.jsp</welcome-file>
    </welcome-file-list>
    
    <!-- Session timeout in minutes -->
    <session-config>
        <session-timeout>30</session-timeout>
    </session-config>
    
    <!-- Login Servlet -->
    <servlet>
        <servlet-name>LoginServlet</servlet-name>
        <servlet-class>com.paperiq.controller.LoginServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>LoginServlet</servlet-name>
        <url-pattern>/login</url-pattern>
    </servlet-mapping>
    
    <!-- Logout Servlet -->
    <servlet>
        <servlet-name>LogoutServlet</servlet-name>
        <servlet-class>com.paperiq.controller.LogoutServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>LogoutServlet</servlet-name>
        <url-pattern>/logout</url-pattern>
    </servlet-mapping>
    
    <!-- Dashboard Servlet -->
    <servlet>
        <servlet-name>DashboardServlet</servlet-name>
        <servlet-class>com.paperiq.controller.DashboardServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>DashboardServlet</servlet-name>
        <url-pattern>/dashboard</url-pattern>
    </servlet-mapping>
    
    <!-- Question Servlet -->
    <servlet>
        <servlet-name>QuestionServlet</servlet-name>
        <servlet-class>com.paperiq.controller.QuestionServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>QuestionServlet</servlet-name>
        <url-pattern>/questions</url-pattern>
    </servlet-mapping>
    
    <!-- Add Question Servlet -->
    <servlet>
        <servlet-name>AddQuestionServlet</servlet-name>
        <servlet-class>com.paperiq.controller.AddQuestionServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>AddQuestionServlet</servlet-name>
        <url-pattern>/add-question</url-pattern>
    </servlet-mapping>
    
    <!-- Edit Question Servlet -->
    <servlet>
        <servlet-name>EditQuestionServlet</servlet-name>
        <servlet-class>com.paperiq.controller.EditQuestionServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>EditQuestionServlet</servlet-name>
        <url-pattern>/edit-question</url-pattern>
    </servlet-mapping>
    
    <!-- Delete Question Servlet -->
    <servlet>
        <servlet-name>DeleteQuestionServlet</servlet-name>
        <servlet-class>com.paperiq.controller.DeleteQuestionServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>DeleteQuestionServlet</servlet-name>
        <url-pattern>/delete-question</url-pattern>
    </servlet-mapping>
    
    <!-- Paper Servlet -->
    <servlet>
        <servlet-name>PaperServlet</servlet-name>
        <servlet-class>com.paperiq.controller.PaperServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>PaperServlet</servlet-name>
        <url-pattern>/generate-paper</url-pattern>
    </servlet-mapping>
    
    <!-- Generate PDF Servlet -->
<servlet>
    <servlet-name>GeneratePDFServlet</servlet-name>
    <servlet-class>com.paperiq.controller.GeneratePDFServlet</servlet-class>
</servlet>
<servlet-mapping>
    <servlet-name>GeneratePDFServlet</servlet-name>
    <url-pattern>/generate-pdf</url-pattern>
</servlet-mapping>

    <!-- History Servlet -->
    <servlet>
        <servlet-name>HistoryServlet</servlet-name>
        <servlet-class>com.paperiq.controller.HistoryServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>HistoryServlet</servlet-name>
        <url-pattern>/paper-history</url-pattern>
    </servlet-mapping>
    
    <!-- Error pages -->
    <error-page>
        <error-code>404</error-code>
        <location>/error.jsp</location>
    </error-page>
    
    <error-page>
        <error-code>500</error-code>
        <location>/error.jsp</location>
    </error-page>
    
</web-app>